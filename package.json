{
  "name": "vad",
  "description": "Application utilizing Sitecore JavaScript Services and Next.js",
  "version": "0.1.0",
  "private": true,
  "config": {
    "appName": "vad",
    "rootPlaceholders": [
      "vad-header",
      "vad-main",
      "vad-footer"
    ],
    "sitecoreConfigPath": "/App_Config/Include/zzz",
    "graphQLEndpointPath": "/sitecore/api/graph/edge",
    "language": "en",
    "templates": [
      "nextjs",
      "nextjs-styleguide",
      "nextjs-styleguide-tracking"
    ]
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://jss.sitecore.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/jss.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/jss/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "@sitecore-jss/sitecore-jss-nextjs": "~22.12.0",
    "bootstrap": "^5.2.3",
    "next": "^16.1.0",
    "next-localization": "^0.12.0",
    "nprogress": "~0.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "sharp": "0.34.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@sitecore-jss/sitecore-jss-cli": "~22.12.0",
    "@sitecore-jss/sitecore-jss-dev-tools": "~22.12.0",
    "@types/node": "^24.10.4",
    "@types/nprogress": "^0.2.0",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "chalk": "~4.1.2",
    "chokidar": "~4.0.3",
    "constant-case": "^3.0.4",
    "cross-env": "~10.0.0",
    "dotenv-flow": "^4.1.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-yaml": "^0.5.0",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "npm-run-all": "~4.1.5",
    "prettier": "^2.8.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "~5.4.0"
  },
  "scripts": {
    "bootstrap": "ts-node --require dotenv-flow/config --project tsconfig.scripts.json scripts/bootstrap.ts",
    "build": "cross-env NODE_ENV=production npm-run-all --serial bootstrap next:build",
    "install-pre-push-hook": "ts-node --project tsconfig.scripts.json ./scripts/install-pre-push-hook.ts",
    "jss": "jss",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts ./scripts/**/*.ts",
    "next:build": "next build --webpack",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev --webpack",
    "next:start": "next start",
    "scaffold": "ts-node --project tsconfig.scripts.json scripts/scaffold-component/index.ts",
    "start": "cross-env NODE_ENV=development JSS_MODE=disconnected \"npm-run-all --serial bootstrap --parallel next:dev start:disconnected-proxy start:watch-components\"",
    "start:connected": "cross-env NODE_ENV=development npm-run-all --serial bootstrap --parallel next:dev start:watch-components",
    "start:disconnected-proxy": "ts-node --project tsconfig.scripts.json ./scripts/disconnected-mode-proxy.ts",
    "start:production": "cross-env-shell NODE_ENV=production npm-run-all --serial bootstrap next:build next:start",
    "start:watch-components": "ts-node --project tsconfig.scripts.json scripts/generate-component-builder/index.ts --watch"
  }
}
